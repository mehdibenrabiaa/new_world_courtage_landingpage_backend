ALLOWED_ORIGINS=["http://localhost:3002"]
API_KEY=change-me
# Local dev falls back to SQLite automatically if this is unset. In
# production (Coolify), point this at a provisioned Postgres instance:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Defaults to "production", which disables /docs, /redoc, and /openapi.json.
# Set to "development" locally to keep the interactive API docs enabled.
ENVIRONMENT=development
